{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {
        "affiliateUrl": { "type": "string", "format": "uri" },
        "productName": { "type": ["string", "null"] },
        "price": { "type": ["string", "null"] },
        "ogImage": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["valid", "invalid"] }
    },
    "views": {
        "overview": {
            "title": "Daraz affiliate links",
            "transformation": {
                "fields": ["affiliateUrl", "productName", "price", "ogImage", "status"]
            },
            "display": {
                "component": "table",
                "properties": {
                    "affiliateUrl": { "label": "Affiliate URL", "format": "link" },
                    "productName": { "label": "Product", "format": "text" },
                    "price": { "label": "Price", "format": "text" },
                    "ogImage": { "label": "Image", "format": "image" },
                    "status": { "label": "Status", "format": "text" }
                }
            }
        }
    }
}
